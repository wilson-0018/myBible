<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>圣经各卷书 - 英汉对照 & 发音</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', 'Helvetica Neue', sans-serif;
    background: #f5f0e8;
    color: #2c2c2c;
    min-height: 100vh;
    padding: 20px;
  }
  .container {
    max-width: 1000px;
    margin: 0 auto;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    padding: 30px;
  }
  h1 {
    font-size: 28px;
    text-align: center;
    color: #5b3a1a;
    margin-bottom: 6px;
    letter-spacing: 2px;
  }
  .subtitle {
    text-align: center;
    color: #888;
    font-size: 14px;
    margin-bottom: 28px;
  }
  .testament {
    margin-bottom: 32px;
  }
  .testament-title {
    font-size: 18px;
    font-weight: 700;
    color: #8b5e3c;
    border-bottom: 2px solid #d4b896;
    padding-bottom: 8px;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .testament-title .count {
    font-size: 13px;
    font-weight: 400;
    color: #999;
    margin-left: auto;
  }
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 8px;
  }
  .book-card {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    border-radius: 10px;
    background: #faf8f5;
    border: 1px solid #ede8e0;
    transition: all 0.2s;
    gap: 10px;
  }
  .book-card:hover {
    background: #f2ece4;
    border-color: #d4b896;
  }
  .book-num {
    font-size: 12px;
    color: #bbb;
    min-width: 26px;
    text-align: right;
    font-weight: 500;
  }
  .book-info {
    flex: 1;
  }
  .book-en {
    font-size: 15px;
    font-weight: 600;
    color: #3a2a1a;
    line-height: 1.4;
  }
  .book-phonetic {
    font-size: 12px;
    color: #999;
    font-family: 'Arial', sans-serif;
    line-height: 1.3;
  }
  .book-cn {
    font-size: 13px;
    color: #666;
    margin-top: 1px;
  }
  .play-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: #d4b896;
    color: #fff;
    cursor: pointer;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .play-btn:hover {
    background: #b8926c;
  }
  .play-btn:active {
    transform: scale(0.92);
  }
  .search-box {
    margin-bottom: 20px;
    position: relative;
  }
  .search-box input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 10px;
    font-size: 15px;
    outline: none;
    transition: border 0.2s;
    background: #faf8f5;
  }
  .search-box input:focus {
    border-color: #b8926c;
    background: #fff;
  }
  .count-bar {
    text-align: center;
    font-size: 13px;
    color: #999;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid #eee;
  }
  .filter-btns {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .filter-btn {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid #ddd;
    background: #fff;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    color: #666;
  }
  .filter-btn:hover {
    border-color: #b8926c;
    color: #5b3a1a;
  }
  .filter-btn.active {
    background: #8b5e3c;
    color: #fff;
    border-color: #8b5e3c;
  }
  @media (max-width: 640px) {
    .container { padding: 16px; }
    .book-grid { grid-template-columns: 1fr; }
    h1 { font-size: 22px; }
  }
</style>
</head>
<body>

<div class="container">
  <h1>📖 圣经各卷书</h1>
  <p class="subtitle">Books of the Bible · 英汉对照 · 点击 🔊 听发音</p>

  <div class="search-box">
    <input type="text" id="searchInput" placeholder="🔍 搜索中文或英文名称..." oninput="filterBooks()">
  </div>

  <div class="filter-btns" id="filterBtns">
    <button class="filter-btn active" onclick="setFilter('all')">全部</button>
    <button class="filter-btn" onclick="setFilter('ot')">旧约</button>
    <button class="filter-btn" onclick="setFilter('nt')">新约</button>
  </div>

  <div id="testaments"></div>

  <div class="count-bar" id="countBar"></div>
</div>

<script>
// ====== 全部数据 ======
const books = {
  ot: [
    { en: "Genesis", phonetic: "/ˈdʒenəsɪs/", cn: "创世记" },
    { en: "Exodus", phonetic: "/ˈeksədəs/", cn: "出埃及记" },
    { en: "Leviticus", phonetic: "/lɪˈvɪtɪkəs/", cn: "利未记" },
    { en: "Numbers", phonetic: "/ˈnʌmbərz/", cn: "民数记" },
    { en: "Deuteronomy", phonetic: "/ˌdjuːtəˈrɒnəmi/", cn: "申命记" },
    { en: "Joshua", phonetic: "/ˈdʒɒʃuə/", cn: "约书亚记" },
    { en: "Judges", phonetic: "/ˈdʒʌdʒɪz/", cn: "士师记" },
    { en: "Ruth", phonetic: "/ruːθ/", cn: "路得记" },
    { en: "1 Samuel", phonetic: "/ˈsæmjuəl/", cn: "撒母耳记上" },
    { en: "2 Samuel", phonetic: "/ˈsæmjuəl/", cn: "撒母耳记下" },
    { en: "1 Kings", phonetic: "/kɪŋz/", cn: "列王纪上" },
    { en: "2 Kings", phonetic: "/kɪŋz/", cn: "列王纪下" },
    { en: "1 Chronicles", phonetic: "/ˈkrɒnɪkəlz/", cn: "历代志上" },
    { en: "2 Chronicles", phonetic: "/ˈkrɒnɪkəlz/", cn: "历代志下" },
    { en: "Ezra", phonetic: "/ˈezrə/", cn: "以斯拉记" },
    { en: "Nehemiah", phonetic: "/ˌniːɪˈmaɪə/", cn: "尼希米记" },
    { en: "Esther", phonetic: "/ˈestər/", cn: "以斯帖记" },
    { en: "Job", phonetic: "/dʒoʊb/", cn: "约伯记" },
    { en: "Psalms", phonetic: "/sɑːmz/", cn: "诗篇" },
    { en: "Proverbs", phonetic: "/ˈprɒvɜːbz/", cn: "箴言" },
    { en: "Ecclesiastes", phonetic: "/ɪˌkliːziˈæstiːz/", cn: "传道书" },
    { en: "Song of Solomon", phonetic: "/ˈsɒləmən/", cn: "雅歌" },
    { en: "Isaiah", phonetic: "/aɪˈzaɪə/", cn: "以赛亚书" },
    { en: "Jeremiah", phonetic: "/ˌdʒerɪˈmaɪə/", cn: "耶利米书" },
    { en: "Lamentations", phonetic: "/ˌlæmenˈteɪʃənz/", cn: "耶利米哀歌" },
    { en: "Ezekiel", phonetic: "/ɪˈziːkiəl/", cn: "以西结书" },
    { en: "Daniel", phonetic: "/ˈdænjəl/", cn: "但以理书" },
    { en: "Hosea", phonetic: "/hoʊˈziːə/", cn: "何西阿书" },
    { en: "Joel", phonetic: "/dʒoʊl/", cn: "约珥书" },
    { en: "Amos", phonetic: "/ˈeɪmɒs/", cn: "阿摩司书" },
    { en: "Obadiah", phonetic: "/ˌoʊbəˈdaɪə/", cn: "俄巴底亚书" },
    { en: "Jonah", phonetic: "/ˈdʒoʊnə/", cn: "约拿书" },
    { en: "Micah", phonetic: "/ˈmaɪkə/", cn: "弥迦书" },
    { en: "Nahum", phonetic: "/ˈneɪəm/", cn: "那鸿书" },
    { en: "Habakkuk", phonetic: "/həˈbækək/", cn: "哈巴谷书" },
    { en: "Zephaniah", phonetic: "/ˌzefəˈnaɪə/", cn: "西番雅书" },
    { en: "Haggai", phonetic: "/ˈhæɡeɪaɪ/", cn: "哈该书" },
    { en: "Zechariah", phonetic: "/ˌzekəˈraɪə/", cn: "撒迦利亚书" },
    { en: "Malachi", phonetic: "/ˈmæləkaɪ/", cn: "玛拉基书" }
  ],
  nt: [
    { en: "Matthew", phonetic: "/ˈmæθjuː/", cn: "马太福音" },
    { en: "Mark", phonetic: "/mɑːrk/", cn: "马可福音" },
    { en: "Luke", phonetic: "/luːk/", cn: "路加福音" },
    { en: "John", phonetic: "/dʒɒn/", cn: "约翰福音" },
    { en: "Acts", phonetic: "/ækts/", cn: "使徒行传" },
    { en: "Romans", phonetic: "/ˈroʊmənz/", cn: "罗马书" },
    { en: "1 Corinthians", phonetic: "/kəˈrɪnθiənz/", cn: "哥林多前书" },
    { en: "2 Corinthians", phonetic: "/kəˈrɪnθiənz/", cn: "哥林多后书" },
    { en: "Galatians", phonetic: "/ɡəˈleɪʃənz/", cn: "加拉太书" },
    { en: "Ephesians", phonetic: "/ɪˈfiːʒənz/", cn: "以弗所书" },
    { en: "Philippians", phonetic: "/fɪˈlɪpiənz/", cn: "腓立比书" },
    { en: "Colossians", phonetic: "/kəˈlɒʃənz/", cn: "歌罗西书" },
    { en: "1 Thessalonians", phonetic: "/ˌθesəˈloʊniənz/", cn: "帖撒罗尼迦前书" },
    { en: "2 Thessalonians", phonetic: "/ˌθesəˈloʊniənz/", cn: "帖撒罗尼迦后书" },
    { en: "1 Timothy", phonetic: "/ˈtɪməθi/", cn: "提摩太前书" },
    { en: "2 Timothy", phonetic: "/ˈtɪməθi/", cn: "提摩太后书" },
    { en: "Titus", phonetic: "/ˈtaɪtəs/", cn: "提多书" },
    { en: "Philemon", phonetic: "/faɪˈliːmən/", cn: "腓利门书" },
    { en: "Hebrews", phonetic: "/ˈhiːbruːz/", cn: "希伯来书" },
    { en: "James", phonetic: "/dʒeɪmz/", cn: "雅各书" },
    { en: "1 Peter", phonetic: "/ˈpiːtər/", cn: "彼得前书" },
    { en: "2 Peter", phonetic: "/ˈpiːtər/", cn: "彼得后书" },
    { en: "1 John", phonetic: "/dʒɒn/", cn: "约翰一书" },
    { en: "2 John", phonetic: "/dʒɒn/", cn: "约翰二书" },
    { en: "3 John", phonetic: "/dʒɒn/", cn: "约翰三书" },
    { en: "Jude", phonetic: "/dʒuːd/", cn: "犹大书" },
    { en: "Revelation", phonetic: "/ˌrevəˈleɪʃən/", cn: "启示录" }
  ]
};

let currentFilter = 'all';

// ====== 渲染函数 ======
function render(filter) {
  const container = document.getElementById('testaments');
  const countBar = document.getElementById('countBar');
  container.innerHTML = '';
  
  let totalCount = 0;

  const renderTestament = (key, label, icon) => {
    const list = books[key];
    const filtered = filter === 'all' ? list : list;
    if (filter !== 'all' && filter !== key) return;

    const section = document.createElement('div');
    section.className = 'testament';
    section.dataset.testament = key;

    const title = document.createElement('div');
    title.className = 'testament-title';
    title.innerHTML = `${icon} ${label} <span class="count">${filtered.length} 卷</span>`;
    section.appendChild(title);

    const grid = document.createElement('div');
    grid.className = 'book-grid';

    filtered.forEach((book, idx) => {
      const card = document.createElement('div');
      card.className = 'book-card';
      card.dataset.search = `${book.en} ${book.cn}`.toLowerCase();

      const num = document.createElement('div');
      num.className = 'book-num';
      const globalIdx = key === 'ot' ? idx + 1 : 39 + idx + 1;
      num.textContent = globalIdx;

      const info = document.createElement('div');
      info.className = 'book-info';

      const enName = document.createElement('div');
      enName.className = 'book-en';
      enName.textContent = book.en;

      const phonetic = document.createElement('div');
      phonetic.className = 'book-phonetic';
      phonetic.textContent = book.phonetic;

      const cnName = document.createElement('div');
      cnName.className = 'book-cn';
      cnName.textContent = book.cn;

      info.appendChild(enName);
      info.appendChild(phonetic);
      info.appendChild(cnName);

      const btn = document.createElement('button');
      btn.className = 'play-btn';
      btn.innerHTML = '🔊';
      btn.title = '点击发音';
      btn.onclick = (e) => {
        e.stopPropagation();
        speak(book.en);
      };

      card.appendChild(num);
      card.appendChild(info);
      card.appendChild(btn);
      grid.appendChild(card);
    });

    section.appendChild(grid);
    container.appendChild(section);
    totalCount += filtered.length;
  };

  renderTestament('ot', '旧约 Old Testament', '📜');
  renderTestament('nt', '新约 New Testament', '✝️');

  countBar.textContent = `共 ${totalCount} 卷书 · 点击喇叭图标听发音`;
}

// ====== 发音 ======
function speak(text) {
  if (!window.speechSynthesis) {
    alert('您的浏览器不支持语音合成');
    return;
  }
  window.speechSynthesis.cancel();
  const utter = new SpeechSynthesisUtterance(text);
  utter.lang = 'en-US';
  utter.rate = 0.85;
  utter.pitch = 1.0;
  
  // 尝试选一个美式英语声音
  const voices = window.speechSynthesis.getVoices();
  const usVoice = voices.find(v => v.lang.startsWith('en-US'));
  if (usVoice) utter.voice = usVoice;
  
  window.speechSynthesis.speak(utter);
}

// ====== 搜索 ======
function filterBooks() {
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  const cards = document.querySelectorAll('.book-card');
  cards.forEach(card => {
    const text = (card.dataset.search || card.textContent.toLowerCase());
    card.style.display = text.includes(q) ? '' : 'none';
  });
}

// ====== 筛选按钮 ======
function setFilter(f) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.classList.toggle('active', btn.textContent === 
      (f === 'all' ? '全部' : f === 'ot' ? '旧约' : '新约'));
  });
  render(f);
}

// 初始化
render('all');

// 预加载语音
if (window.speechSynthesis) {
  window.speechSynthesis.getVoices();
  window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();
}
</script>
</body>
</html>
